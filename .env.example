# ============================================================
# FinanX — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayıp ".env" olarak kaydedin ve
# gerçek değerlerinizi girin.
# ============================================================

# --- LLM Sağlayıcısı ---
# Google Gemini (önerilen): https://aistudio.google.com/
GOOGLE_API_KEY=your_google_gemini_api_key_here

# OpenAI (alternatif): https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Aktif LLM sağlayıcısını seçin: "google" veya "openai"
LLM_PROVIDER=google
LLM_MODEL=gemini-1.5-pro

# --- Telegram Bildirim Sistemi ---
# BotFather üzerinden bot oluşturun: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Chat ID'nizi öğrenmek için: https://t.me/userinfobot
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Veritabanı ---
DATABASE_URL=sqlite+aiosqlite:///./data/finanx.db

# --- FastAPI Sunucusu ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_random_secret_key
DEBUG=True

# --- Streamlit Frontend ---
BACKEND_URL=http://localhost:8000

# --- RAG Konfigürasyonu ---
# Embedding modeli (yerel, ücretsiz)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
FAISS_INDEX_PATH=./data/faiss_index
PDF_REPORTS_PATH=./data/reports

# Chunk boyutu ve çakışma
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_TOP_K=5

# --- Zamanlayıcı ---
# KAP ve borsa kontrol aralığı (dakika cinsinden)
WATCHER_INTERVAL_MINUTES=5
